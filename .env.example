# Supabase — preencha com os dados do seu projeto (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# OpenAI (GPT) — IA de título, "inspire-se" e chat de ajuda. Só servidor.
OPENAI_API_KEY=sk-...
# Opcional (padrão: gpt-4o-mini):
# OPENAI_MODEL=gpt-4o-mini

# RapidAPI — "Inspire-se": ao colar um link de faixa do Spotify, puxa as métricas
# reais (BPM, energia, humor, tom…) da spotify-extended-audio-features-api.
# Somente servidor, NÃO use NEXT_PUBLIC_. (RapidAPI → Apps → Security → App Key.)
RAPIDAPI_KEY=...

# Suno (sunoapi.org / apibox) — somente servidor, NÃO use NEXT_PUBLIC_
SUNO_KEY=506bc6e33f4be96dab9a36ca15aebe05
# Opcionais (têm padrão no código):
# SUNO_API_URL=https://apibox.erweima.ai
# SUNO_MODEL=V5_5
# SUNO_CALLBACK_URL=https://seu-dominio/api/suno-callback

# Cloudflare R2 — opcional pra músicas normais (re-hospeda áudio/capa da Suno,
# cuja URL expira; sem essas vars, o app usa a URL da Suno direto), mas
# OBRIGATÓRIO pro Jingle Comercial (/jingle): os 4 clipes cortados pelo FFmpeg
# (full/15s/30s/60s) só existem no R2, não há fallback pra Suno nesse caso.
# Painel R2 → Manage API Tokens → criar token "Object Read & Write".
# R2_ACCOUNT_ID=seu-account-id-cloudflare
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=starsonic-media
# URL pública do bucket (domínio customizado ou o *.r2.dev habilitado no painel)
# R2_PUBLIC_URL=https://media.seu-dominio.com
